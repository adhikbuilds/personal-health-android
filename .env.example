# Android App — Environment Variables
# Copy this file to .env if using react-native-config or similar

# Your machine's Wi-Fi IP (run: ipconfig on Windows)
BACKEND_HOST=192.168.1.100

# Frontend proxy port (recommended for Android — bypasses Windows Firewall)
PROXY_PORT=8083

# Backend FastAPI direct port (used for Phase 2 WebSocket)
FASTAPI_PORT=8082
