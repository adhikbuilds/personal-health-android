# ActiveBharat Android — Environment Config
# Copy to .env and set values. Used by app.config.js at build time.

# dev | staging | production
APP_ENV=dev

# Backend host (no protocol, no port)
# dev: localhost (uses adb reverse)
# staging: staging-api.activebharat.in
# production: api.activebharat.in
BACKEND_HOST=localhost
