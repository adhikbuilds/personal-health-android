# ─── Node.js ─────────────────────────────────────────────────────────────────
# All installed npm/yarn packages – restored via npm install
node_modules/

# ─── Expo CLI ────────────────────────────────────────────────────────────────
# Generated by Expo Go and expo-cli at runtime; contains device cache & local state
.expo/

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
!.env.example

# ─── Expo / Metro Build Artifacts ────────────────────────────────────────────
# Production JS bundles generated by metro bundler
*.jsbundle
*.jsbundle.map

# ─── Expo Web ────────────────────────────────────────────────────────────────
web-build/

# ─── Android Native Build ────────────────────────────────────────────────────
# Gradle daemon cache and incremental build outputs (often hundreds of MB)
android/.gradle/
android/build/
android/app/build/
android/.idea/
# Per-machine local SDK path – never commit
android/local.properties
# IntelliJ / Android Studio module files
android/*.iml
android/**/*.iml
android/.cxx/
# Gradle native build outputs
android/app/.cxx/

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
*.log
